// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum role {
  ADMIN
  RT
  RW
  WARGA
}

model User {
  id         Int              @id @default(autoincrement())
  Username   String           @unique
  Email      String           @unique
  Password   String
  Role       role             @default(WARGA)
  Created_at DateTime         @default(now())
  Updated_at DateTime         @updatedAt
  identities IdentityMember[]
  villages   Village[]
}

model Announcement {
  id        Int            @id @default(autoincrement())
  Title     String
  Content   String
  AuthorId  Int
  Author    IdentityMember @relation(fields: [AuthorId], references: [id])
  RwId      Int
  RtId      Int
  Rw        Rw             @relation(fields: [RwId], references: [Id])
  Rt        Rt             @relation(fields: [RtId], references: [Id])
  CreatedAt DateTime       @default(now())
}

model Village {
  id               Int              @id @default(autoincrement())
  Name             String
  Address          String
  Total_Population Int
  Village_Age      Int
  Leader_VillageId Int
  Leader_Village   User             @relation(fields: [Leader_VillageId], references: [id])
  identityVilages  IdentityMember[]
}

model IdentityMember {
  id            Int            @id @default(autoincrement())
  VillageId     Int
  Village       Village        @relation(fields: [VillageId], references: [id])
  User_Id       Int
  User          User           @relation(fields: [User_Id], references: [id])
  Full_Name     String         @unique
  RtId          Int
  RwId          Int
  Rw            Rw             @relation(fields: [RwId], references: [Id])
  Rt            Rt             @relation(fields: [RtId], references: [Id])
  Age           Int
  Address       String
  Created_at    DateTime       @default(now())
  Updated_at    DateTime       @default(now())
  announcements Announcement[]
}

model Rw {
  Id            Int              @id @default(autoincrement())
  Name          String
  rts           Rt[]
  identities    IdentityMember[]
  announcements Announcement[]
}

model Rt {
  Id            Int              @id @default(autoincrement())
  Number        Int
  RwId          Int
  Rw            Rw               @relation(fields: [RwId], references: [Id])
  identities    IdentityMember[]
  announcements Announcement[]
}
