// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum role {
  KEPALA_DESA
  RT
  RW
  WARGA
}

model User {
  id            Int            @id @default(autoincrement())
  Username      String         @unique
  Email         String         @unique
  Address       String
  Password      String
  Role          role?          @default(WARGA)
  Avatar        String?
  VillageId     Int
  Village       Village        @relation(fields: [VillageId], references: [id])
  Created_at    DateTime       @default(now())
  Updated_at    DateTime       @updatedAt
  announcements Announcement[]
  submissions   Submissions[]
}

model Digital_Signature {
  id               Int         @id @default(autoincrement())
  No_surat_desa    Int
  SubmissionsId    Int
  Submissions      Submissions @relation(fields: [SubmissionsId], references: [id])
  Kepala_desa_sign Boolean
  Rt_desa_sign     Boolean
}

enum Tipe_Surat {
  DOMISILI
  KURANG_MAMPU
  NIKAH
  KEMATIAN
  USAHA
}

model Submissions {
  id                   Int                 @id @default(autoincrement())
  Nomor_surat_rt       Int
  UserId               Int
  User                 User                @relation(fields: [UserId], references: [id])
  RtId                 Int
  Rt                   Rt                  @relation(fields: [RtId], references: [Id])
  RwId                 Int
  Rw                   Rw                  @relation(fields: [RwId], references: [Id])
  Dokumen_pengajuan    String
  Tipe_Surat           Tipe_Surat
  Status               String?             @default("PENDING")
  Keterangan_pengajuan String?             @default("DIAJUKAN")
  Keperluan            String
  Tanggal_pengajuan    DateTime
  Tanggal_Selesai      DateTime?
  digitalSignatures    Digital_Signature[]
}

model Announcement {
  id        Int      @id @default(autoincrement())
  Title     String
  Content   String
  Image     String
  AuthorId  Int
  Author    User     @relation(fields: [AuthorId], references: [id])
  RwId      Int
  RtId      Int
  Rw        Rw       @relation(fields: [RwId], references: [Id])
  Rt        Rt       @relation(fields: [RtId], references: [Id])
  CreatedAt DateTime @default(now())
}

model Village {
  id               Int    @id @default(autoincrement())
  Name             String
  Address          String
  Total_Population Int
  Village_Age      Int
  Leader_VillageId Int
  users            User[]
}

model Rw {
  Id            Int            @id @default(autoincrement())
  Name          String
  rts           Rt[]
  announcements Announcement[]
  submissions   Submissions[]
}

model Rt {
  Id            Int            @id @default(autoincrement())
  Number        Int
  RwId          Int
  Rw            Rw             @relation(fields: [RwId], references: [Id])
  announcements Announcement[]
  submissions   Submissions[]
}
