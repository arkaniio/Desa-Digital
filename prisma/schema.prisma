// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum role {
  KEPALA_DESA
  RT
  RW
  WARGA
}

model User {
  id            Int            @id @default(autoincrement())
  Username      String         @unique
  Email         String         @unique
  Address       String
  Password      String
  Role          role?          @default(WARGA)
  Avatar        String?
  Created_at    DateTime       @default(now())
  Updated_at    DateTime       @updatedAt
  // Setiap user terikat pada struktur Desa, RW, dan RT mereka tempat mereka tinggal tinggal
  VillageId     Int
  Village       Village        @relation("VillageMembers", fields: [VillageId], references: [id])
  RwId          Int
  Rw            Rw             @relation("RwMembers", fields: [RwId], references: [Id])
  RtId          Int
  Rt            Rt             @relation("RtMembers", fields: [RtId], references: [Id])
  // Back-relation untuk jabatan kepemimpinan
  LedVillages   Village[]      @relation("VillageLeader")
  LedRws        Rw[]           @relation("RwLeader")
  LedRts        Rt[]           @relation("RtLeader")
  announcements Announcement[]
  submissions   Submissions[]
}

model Village {
  id               Int    @id @default(autoincrement())
  Name             String @unique
  Address          String
  Total_Population Int
  Village_Age      Int

  // Hubungan ke Kepala Desa
  Leader_VillageId Int
  Leader_Village   User @relation("VillageLeader", fields: [Leader_VillageId], references: [id])

  users User[] @relation("VillageMembers")
  rws   Rw[]
}

model Rw {
  Id        Int     @id @default(autoincrement())
  Name      String // Contoh: "RW 01"
  VillageId Int
  Village   Village @relation(fields: [VillageId], references: [id])

  // Hubungan ke Ketua RW (opsional jika jabatan sedang kosong)
  Leader_Id     Int?
  Leader        User?          @relation("RwLeader", fields: [Leader_Id], references: [id])
  rts           Rt[]
  announcements Announcement[]
  submissions   Submissions[]
  users         User[]         @relation("RwMembers")
}

model Rt {
  Id     Int @id @default(autoincrement())
  Number Int // Contoh: 3 (artinya RT 03)
  RwId   Int
  Rw     Rw  @relation(fields: [RwId], references: [Id])

  // Hubungan ke Ketua RT (opsional jika jabatan sedang kosong)
  Leader_Id     Int?
  Leader        User?          @relation("RtLeader", fields: [Leader_Id], references: [id])
  announcements Announcement[]
  submissions   Submissions[]
  users         User[]         @relation("RtMembers")
}

enum Tipe_Surat {
  SURAT_DOMISILI
  SURAT_KURANG_MAMPU
  SURAT_NIKAH
  SURAT_KEMATIAN
  SURAT_USAHA
}

model Submissions {
  id                   Int        @id @default(autoincrement())
  Nomor_surat_rt       Int
  SenderId             Int
  Sender               User       @relation(fields: [SenderId], references: [id])
  RtId                 Int
  Rt                   Rt         @relation(fields: [RtId], references: [Id])
  RwId                 Int
  Rw                   Rw         @relation(fields: [RwId], references: [Id])
  Dokumen_pengajuan    String // URL bukti pendukung di Cloudinary (KTP/KK)
  Tipe_Surat           Tipe_Surat
  Status               String?    @default("PENDING") // PENDING, APPROVED_RT, SUCCESS, REJECTED
  Keterangan_pengajuan String?    @default("DIAJUKAN")
  Keperluan            String
  Tanggal_pengajuan    DateTime   @default(now())
  Tanggal_selesai      DateTime?

  // Tanda Tangan Terintegrasi (Menghilangkan tabel Digital_Signature yang rawan celah)
  Rt_desa_sign     Boolean @default(false)
  Kepala_desa_sign Boolean @default(false)

  // Untuk fitur pengesahan surat publik
  QrCodeSignature String? @unique
}

model Announcement {
  id          Int      @id @default(autoincrement())
  Title       String
  Content     String
  Image       String
  AuthorId    Int
  Author      User     @relation(fields: [AuthorId], references: [id])
  RwId        Int
  RtId        Int
  Rw          Rw       @relation(fields: [RwId], references: [Id])
  Rt          Rt       @relation(fields: [RtId], references: [Id])
  Dibuat_pada DateTime @default(now())
}
